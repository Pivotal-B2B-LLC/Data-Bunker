{
  "name": "data-bunker-backend",
  "version": "1.0.0",
  "description": "Backend API for global company search platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --detectOpenHandles",
    "agents": "node scripts/agents/master-turbo.js",
    "email:intelligence:backfill": "node scripts/backfill-email-intelligence.js",
    "pipeline": "node scripts/smart-enrichment-pipeline.js",
    "pm2:start": "pm2 start ../ecosystem.config.js",
    "pm2:stop": "pm2 stop all",
    "pm2:restart": "pm2 restart all",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "discovery:start": "pm2 start ../ecosystem.config.js --only databunker-discovery",
    "discovery:stop": "pm2 stop databunker-discovery",
    "discovery:restart": "pm2 restart databunker-discovery",
    "discovery:logs": "pm2 logs databunker-discovery --lines 100",
    "discovery:run": "node scripts/auto-discover-all.js --workers=1"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "cheerio": "^1.1.2",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.3.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "joi": "^17.11.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.2",
    "openai": "^6.15.0",
    "pg": "^8.16.3",
    "puppeteer": "^24.34.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
