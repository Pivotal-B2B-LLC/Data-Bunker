{
  "manifest_version": 3,
  "name": "Data Banker — B2B Lead Scraper",
  "version": "7.0.0",
  "description": "Premium B2B lead extraction. LinkedIn, Apollo, OpenCorporates, and any directory.",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "*://*/*",
    "http://localhost:5000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Data Bunker Scraper",
    "default_icons": {
      "16": "icon-16.png",
      "24": "icon-24.png",
      "32": "icon-32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}